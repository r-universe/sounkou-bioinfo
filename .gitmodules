[submodule ".registry"]
	path = .registry
	url = https://github.com/sounkou-bioinfo/sounkou-bioinfo.r-universe.dev
	branch = HEAD
[submodule "GenomeScaleEmbeddings"]
	path = GenomeScaleEmbeddings
	url = https://github.com/sounkou-bioinfo/GenomeScaleEmbeddings
[submodule "RSimpleFFI"]
	path = RSimpleFFI
	url = https://github.com/sounkou-bioinfo/RSimpleFFI
[submodule "Rducks"]
	path = Rducks
	url = https://github.com/sounkou-bioinfo/Rducks
[submodule "Rfmalloc"]
	path = Rfmalloc
	url = https://github.com/sounkou-bioinfo/Rfmalloc
[submodule "Rpixpack"]
	path = Rpixpack
	url = https://github.com/sounkou-bioinfo/pixpack
[submodule "Rsassy"]
	path = Rsassy
	url = https://github.com/sounkou-bioinfo/sassy
	subdir = r/Rsassy
[submodule "Rtinycc"]
	path = Rtinycc
	url = https://github.com/sounkou-bioinfo/Rtinycc
[submodule "duckdbWasmHtmlJsSimple"]
	path = duckdbWasmHtmlJsSimple
	url = https://github.com/sounkou-bioinfo/duckdb-wasm-html-js-simple
[submodule "goserveR"]
	path = goserveR
	url = https://github.com/sounkou-bioinfo/goServeR
[submodule "hellomojo"]
	path = hellomojo
	url = https://github.com/sounkou-bioinfo/hellomojo
[submodule "mangoro"]
	path = mangoro
	url = https://github.com/sounkou-bioinfo/mangoro
[submodule "s7contract"]
	path = s7contract
	url = https://github.com/sounkou-bioinfo/s7contract
[submodule "tccquickr"]
	path = tccquickr
	url = https://github.com/sounkou-bioinfo/tccquickr
[submodule "treesitter.c"]
	path = treesitter.c
	url = https://github.com/sounkou-bioinfo/treesitter.c
[submodule "wasmer"]
	path = wasmer
	url = https://github.com/sounkou-bioinfo/wasmer
